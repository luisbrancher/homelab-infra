auth_enabled: false

server:
  http_listen_port: {{ loki_port }}

# recebe os logs e os organiza antes de gravar no disco
ingester:
  lifecycler:
    ring:
      kvstore:
        store: inmemory
      replication_factor: 1
  # tempo que os logs ficam em memória antes de ir pro disco
  chunk_idle_period: 5m
  chunk_retain_period: 30s

schema_config:
  configs:
    - from: 2024-01-01
      store: boltdb-shipper
      object_store: filesystem
      schema: v11
      index:
        prefix: index_
        period: 24h

storage_config:
  boltdb_shipper:
    # onde ficam os índices dos logs
    active_index_directory: /var/loki/index
    cache_location: /var/loki/cache
  filesystem:
    # onde ficam os logs em si
    chunks_directory: /var/loki/chunks

limits_config:
  reject_old_samples: true
  # rejeita logs com mais de 1 semana de atraso
  reject_old_samples_max_age: 168h